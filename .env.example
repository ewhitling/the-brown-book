# Optional. The public repo's build does not call the Anthropic API —
# apply-corrections is deterministic. This variable is defensive: it's
# only used if a task ever invokes a build-time extraction script that
# was intended to run from analysis-botns.
ANTHROPIC_API_KEY=

# Vite build-time env vars (exposed to client bundle via import.meta.env.VITE_*).
# Set in the Cloudflare Pages dashboard under Settings > Environment variables.
# For local dev these are optional; the app degrades gracefully without them.
VITE_REPO_OWNER=ewhitling
VITE_REPO_NAME=the-brown-book
VITE_DEPLOY_ENV=prod
