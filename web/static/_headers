# botns.db is a large static file (~12 MB) that only changes on deploy.
# CF Pages purges the cache on every deploy, so 1-day TTL is safe.
/botns.db
  Cache-Control: public, max-age=86400

# Vite adds content hashes to all JS/CSS asset filenames — cache indefinitely.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
